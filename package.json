{
  "name": "gdcsweb",
  "version": "1.8.1",
  "description": "Doks theme",
  "author": "Thulite",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/thuliteio/doks.git"
  },
  "scripts": {
    "predev": "node scripts/prepare-content.js && node scripts/copy-css.js",
    "create": "hugo new",
    "dev": "hugo server --disableFastRender --noHTTPCache",
    "format": "prettier **/** -w -c",
    "build": "hugo --minify --gc",
    "preview": "vite preview --outDir public"
  },
  "dependencies": {
    "@tabler/icons": "3.34.1",
    "@thulite/doks-core": "1.8.3",
    "@thulite/images": "3.3.1",
    "@thulite/inline-svg": "1.2.0",
    "@thulite/seo": "2.4.1",
    "js-yaml": "4.1.1",
    "lodash": "4.18.1",
    "thulite": "2.6.3"
  },
  "devDependencies": {
    "@changesets/changelog-github": "0.5.1",
    "@changesets/cli": "2.31.0",
    "prettier": "3.6.2",
    "purgecss-whitelister": "2.4.0",
    "vite": "7.3.2"
  },
  "engines": {
    "node": ">=20.11.0"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
