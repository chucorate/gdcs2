{
  "name": "gdcsweb",
  "version": "1.8.1",
  "description": "Doks theme",
  "author": "Thulite",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/thuliteio/doks.git"
  },
  "scripts": {
    "predev": "node scripts/prepare-content.js && node scripts/copy-css.js && node scripts/copy-assets-for-decap-preview.js",
    "create": "hugo new",
    "dev": "hugo server --disableFastRender --noHTTPCache",
    "format": "prettier **/** -w -c",
    "build": "hugo --minify --gc",
    "preview": "vite preview --outDir public"
  },
  "dependencies": {
    "@docsearch/css": "4.6.3",
    "@docsearch/js": "4.6.3",
    "@tabler/icons": "3.44.0",
    "@thulite/doks-core": "1.9.3",
    "@thulite/images": "3.3.4",
    "@thulite/inline-svg": "1.2.2",
    "@thulite/seo": "2.4.3",
    "js-yaml": "4.2.0",
    "lodash": "4.18.1",
    "thulite": "2.6.5"
  },
  "devDependencies": {
    "@changesets/changelog-github": "0.5.1",
    "@changesets/cli": "2.31.0",
    "prettier": "^3.6.2",
    "purgecss-whitelister": "2.4.0",
    "vite": "8.0.16"
  },
  "engines": {
    "node": ">=20.11.0"
  },
  "overrides": {
    "js-yaml": "4.2.0"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
